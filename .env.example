# On Render: add PYTHONUNBUFFERED=1 in Environment for faster log visibility (optional but recommended).
VERIFY_TOKEN=
# Use WHATSAPP_TOKEN for the Graph API user token. If both WHATSAPP_TOKEN and ACCESS_TOKEN are set,
# WHATSAPP_TOKEN wins — a stale WHATSAPP_TOKEN will ignore a new ACCESS_TOKEN (common 401 cause on Render).
WHATSAPP_TOKEN=
PHONE_NUMBER_ID=
GEMINI_API_KEY=
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2
